# Copy this to .env.local for local dev, or set in Vercel project env vars.

# ============================================================================
#  REQUIRED — the app won't work without these
# ============================================================================

# Google Gemini — free at https://aistudio.google.com/app/apikey
# Used by all 5 LLM endpoints (extract, brief, match, photo, linkedin) +
# the daily calendar-scan cron.
GEMINI_API_KEY=...

# Supabase — Project Settings -> API
# URL and anon key are exposed via /api/config to the frontend; service-role
# key is server-only (used by cron + OAuth token storage + admin operations).
SUPABASE_URL=https://xxxxxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Vercel Cron — random 32-char string. When set, Vercel passes it as
# Authorization: Bearer for the daily calendar-scan endpoint. Also serves
# as the fallback secret for OAuth state signing (see OAUTH_STATE_SECRET below).
CRON_SECRET=...

# ============================================================================
#  TRANSACTIONAL EMAIL — Resend (for calendar nudge emails + invite delivery)
# ============================================================================

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Steve <onboarding@resend.dev>

# ============================================================================
#  MICROSOFT 365 OAUTH — only needed if you want one-click Outlook calendar
# ============================================================================

# Azure App Registration — see docs/whitepaper.md §4.6 walkthrough
MICROSOFT_CLIENT_ID=...
MICROSOFT_CLIENT_SECRET=...
MICROSOFT_TENANT_ID=common

# Dedicated secret for HMAC-signing OAuth state tokens. STRONGLY RECOMMENDED
# to set this separately from CRON_SECRET. If not set, the app falls back to
# CRON_SECRET. If neither is set, the app FAILS LOUDLY rather than using a
# guessable default — an attacker with a guessable secret could forge state
# and silently link their own Microsoft account to a victim's session.
OAUTH_STATE_SECRET=...

# ============================================================================
#  OPTIONAL MODEL PROVIDERS — drop in any of these to expand the
#  multi-model routing layer. The router skips providers without keys.
# ============================================================================

# Anthropic Claude — used as the preferred 'brief' model when set
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — used as a vision-capable fallback for photo OCR
OPENAI_API_KEY=sk-...

# Cerebras Cloud — fastest free-tier Llama inference (sub-second)
CEREBRAS_API_KEY=...

# Groq — also fast Llama inference, free tier
GROQ_API_KEY=...

# DeepSeek — best quality-per-dollar
DEEPSEEK_API_KEY=...

# Mistral — EU compliance option
MISTRAL_API_KEY=...

# Kimi K2 (Moonshot AI) — strong reasoning, 32k context
KIMI_API_KEY=...
# (alternative env var accepted by the same adapter)
# MOONSHOT_API_KEY=...

# Perplexity — Sonar models with built-in web search (used in linkedin enrich
# when the URL fetch is blocked)
PERPLEXITY_API_KEY=...

# xAI Grok 4 — vision-capable
XAI_API_KEY=...

# ============================================================================
#  PER-TASK MODEL ROUTING OVERRIDES (optional)
# ============================================================================
# Comma-separated provider order per task. The router tries each in order
# and falls through on error. See api/_models.js DEFAULTS_BY_TASK for the
# defaults if these are unset.
#
# MODEL_BRIEF=anthropic,kimi,deepseek,gemini
# MODEL_EXTRACT=cerebras,groq,gemini,deepseek
# MODEL_MATCH=cerebras,groq,gemini,openai
# MODEL_PHOTO=gemini,openai,xai
# MODEL_LINKEDIN=cerebras,gemini,perplexity,anthropic
# MODEL_CALENDAR=cerebras,gemini,deepseek
# MODEL_DEFAULT=gemini
